EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
EXPO_PUBLIC_BURSRADAR_WEB_URL=https://your-domain.com/bursradar/BursRadar.html

# ─── Bot / Scraper (sunucu tarafı, mobil uygulamaya dahil DEĞİL) ──────────────
# Supabase Dashboard → Settings → API → service_role (secret) anahtarı.
# ASLA EXPO_PUBLIC_ öneki kullanma — bu anahtar uygulamaya gömülmez.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Bot sunucusu için erişim jetonu (isteğe bağlı ama önerilir).
# POST /run-bot isteğinde Authorization: Bearer <bu-değer> gönderilmesi gerekir.
BOT_SERVER_TOKEN=change-this-to-a-random-secret

# Supabase Edge Function için paylaşılan sır.
# Supabase Dashboard → Edge Functions → run-bot → Secrets bölümüne ekle.
# Aynı değeri buraya da yaz ki bot-server doğru başlık göndersin.
SUPABASE_BOT_SECRET=change-this-to-a-random-secret

# Paket talebi mail bildirimi icin Supabase Edge Function secret'lari.
# Supabase Dashboard -> Edge Functions -> package-request-notify -> Secrets.
RESEND_API_KEY=re_your-resend-api-key
PACKAGE_REQUEST_MAIL_TO=orcun@bursradar.app
PACKAGE_REQUEST_MAIL_FROM=BursRadar <noreply@bursradar.app>

# Yerel bot sunucusu adresi (isteğe bağlı).
BOT_SERVER_PORT=8787
BOT_SERVER_HOST=127.0.0.1
